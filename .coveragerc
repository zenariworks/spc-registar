[run]
# Measured from the crkva/ working dir (where manage.py test discovers tests).
source =
    registar
    kalendar
    tenants
omit =
    */migrations/*
    */tests/*
    */test_*.py
    */__init__.py
    */apps.py

[report]
show_missing = false
skip_covered = false
# #303: спроведи минималну покривеност да не би тихо опадала. Тренутно ~66%;
# праг постављен испод тога као под — може се подизати временом.
fail_under = 60
exclude_also =
    if TYPE_CHECKING:
    raise NotImplementedError
    def __repr__
